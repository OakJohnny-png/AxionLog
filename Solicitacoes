import { useState } from 'react';
import { useApp, Pedido, Material } from '@/contexts/AppContext';
import { Card } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger } from '@/components/ui/dialog';
import { Plus, Trash2, Edit2, FileText } from 'lucide-react';

export default function Solicitacoes() {
  const { pedidos, adicionarPedido, atualizarPedido } = useApp();
  const [dialogAberto, setDialogAberto] = useState(false);
  const [editandoId, setEditandoId] = useState<number | null>(null);

  // Form state
  const [formData, setFormData] = useState({
    numero: '',
    cliente: '',
    os: '',
    data: new Date().toISOString().split('T')[0],
    dataPrevista: '',
    materiais: [] as Material[],
  });

  const [materialAtual, setMaterialAtual] = useState({
    codigo: '',
    descricao: '',
    quantidade: 1,
    unidade: 'unidades',
    localizacao: '',
  });

  const handleAdicionarMaterial = () => {
    if (!materialAtual.codigo || !materialAtual.descricao) {
      alert('Preencha código e descrição do material');
      return;
    }

    const novaMaterial: Material = {
      ...materialAtual,
      quantidade: parseInt(materialAtual.quantidade.toString()) || 1,
    };

    setFormData({
      ...formData,
      materiais: [...formData.materiais, novaMaterial],
    });

    setMaterialAtual({
      codigo: '',
      descricao: '',
      quantidade: 1,
      unidade: 'unidades',
      localizacao: '',
    });
  };

  const handleRemoverMaterial = (index: number) => {
    setFormData({
      ...formData,
      materiais: formData.materiais.filter((_, i) => i !== index),
    });
  };

  const handleCriarPedido = () => {
    if (!formData.numero || !formData.cliente || !formData.os) {
      alert('Preencha número, cliente e OS');
      return;
    }

    if (formData.materiais.length === 0) {
      alert('Adicione pelo menos um material');
      return;
    }

    const novoPedido: Pedido = {
      id: Date.now(),
      numero: formData.numero,
      cliente: formData.cliente,
      os: formData.os,
      data: formData.data,
      dataPrevista: formData.dataPrevista,
      materiais: formData.materiais,
      status: 'pendente',
    };

    adicionarPedido(novoPedido);
    setDialogAberto(false);
    resetarForm();
  };

  const resetarForm = () => {
    setFormData({
      numero: '',
      cliente: '',
      os: '',
      data: new Date().toISOString().split('T')[0],
      dataPrevista: '',
      materiais: [],
    });
    setMaterialAtual({
      codigo: '',
      descricao: '',
      quantidade: 1,
      unidade: 'unidades',
      localizacao: '',
    });
    setEditandoId(null);
  };

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'pendente':
        return 'bg-yellow-100 text-yellow-800';
      case 'preparando':
        return 'bg-blue-100 text-blue-800';
      case 'pronto':
        return 'bg-green-100 text-green-800';
      case 'despachado':
        return 'bg-gray-100 text-gray-800';
      default:
        return 'bg-gray-100 text-gray-800';
    }
  };

  return (
    <div className="space-y-6">
      {/* Header com Botão de Criar */}
      <div className="flex items-center justify-between">
        <h2 className="text-2xl font-bold text-foreground">Solicitações de Pedidos</h2>
        <Dialog open={dialogAberto} onOpenChange={setDialogAberto}>
          <DialogTrigger asChild>
            <Button className="bg-accent text-accent-foreground">
              <Plus size={18} className="mr-2" />
              Novo Pedido
            </Button>
          </DialogTrigger>
          <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
            <DialogHeader>
              <DialogTitle>Criar Novo Pedido</DialogTitle>
            </DialogHeader>

            <div className="space-y-4">
              {/* Informações Básicas */}
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="text-sm font-semibold text-foreground">Número do Pedido</label>
                  <Input
                    placeholder="PED-2026-001"
                    value={formData.numero}
                    onChange={(e) => setFormData({ ...formData, numero: e.target.value })}
                  />
                </div>
                <div>
                  <label className="text-sm font-semibold text-foreground">OS</label>
                  <Input
                    placeholder="001"
                    value={formData.os}
                    onChange={(e) => setFormData({ ...formData, os: e.target.value })}
                  />
                </div>
              </div>

              <div>
                <label className="text-sm font-semibold text-foreground">Cliente</label>
                <Input
                  placeholder="Nome do cliente"
                  value={formData.cliente}
                  onChange={(e) => setFormData({ ...formData, cliente: e.target.value })}
                />
              </div>

              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="text-sm font-semibold text-foreground">Data</label>
                  <Input
                    type="date"
                    value={formData.data}
                    onChange={(e) => setFormData({ ...formData, data: e.target.value })}
                  />
                </div>
                <div>
                  <label className="text-sm font-semibold text-foreground">Data Prevista</label>
                  <Input
                    type="date"
                    value={formData.dataPrevista}
                    onChange={(e) => setFormData({ ...formData, dataPrevista: e.target.value })}
                  />
                </div>
              </div>

              {/* Adicionar Materiais */}
              <div className="border-t border-border pt-4">
                <h3 className="font-semibold text-foreground mb-3">Materiais</h3>
                <div className="space-y-3">
                  <div className="grid grid-cols-2 gap-3">
                    <Input
                      placeholder="Código"
                      value={materialAtual.codigo}
                      onChange={(e) => setMaterialAtual({ ...materialAtual, codigo: e.target.value })}
                    />
                    <Input
                      placeholder="Descrição"
                      value={materialAtual.descricao}
                      onChange={(e) => setMaterialAtual({ ...materialAtual, descricao: e.target.value })}
                    />
                  </div>
                  <div className="grid grid-cols-3 gap-3">
                    <Input
                      type="number"
                      placeholder="Quantidade"
                      value={materialAtual.quantidade}
                      onChange={(e) => setMaterialAtual({ ...materialAtual, quantidade: parseInt(e.target.value) || 1 })}
                    />
                    <Input
                      placeholder="Unidade"
                      value={materialAtual.unidade}
                      onChange={(e) => setMaterialAtual({ ...materialAtual, unidade: e.target.value })}
                    />
                    <Button onClick={handleAdicionarMaterial} variant="outline">
                      Adicionar
                    </Button>
                  </div>
                </div>

                {/* Lista de Materiais Adicionados */}
                {formData.materiais.length > 0 && (
                  <div className="mt-4 space-y-2">
                    {formData.materiais.map((material, idx) => (
                      <div key={idx} className="flex items-center justify-between p-3 bg-secondary rounded-lg">
                        <div>
                          <p className="font-mono text-sm font-semibold text-foreground">{material.codigo}</p>
                          <p className="text-xs text-muted-foreground">{material.descricao}</p>
                          <p className="text-xs text-muted-foreground">
                            {material.quantidade} {material.unidade}
                          </p>
                        </div>
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => handleRemoverMaterial(idx)}
                        >
                          <Trash2 size={16} className="text-destructive" />
                        </Button>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              {/* Botões de Ação */}
              <div className="flex gap-2 pt-4 border-t border-border">
                <Button
                  variant="outline"
                  className="flex-1"
                  onClick={() => {
                    setDialogAberto(false);
                    resetarForm();
                  }}
                >
                  Cancelar
                </Button>
                <Button
                  className="flex-1 bg-accent text-accent-foreground"
                  onClick={handleCriarPedido}
                >
                  Criar Pedido
                </Button>
              </div>
            </div>
          </DialogContent>
        </Dialog>
      </div>

      {/* Lista de Pedidos */}
      {pedidos.length === 0 ? (
        <Card className="p-12 text-center">
          <FileText className="mx-auto text-muted-foreground mb-4" size={48} />
          <p className="text-muted-foreground mb-4">Nenhum pedido criado ainda</p>
          <Button className="bg-accent text-accent-foreground" onClick={() => setDialogAberto(true)}>
            <Plus size={18} className="mr-2" />
            Criar Primeiro Pedido
          </Button>
        </Card>
      ) : (
        <div className="grid gap-4">
          {pedidos.map((pedido) => (
            <Card key={pedido.id} className="p-6">
              <div className="flex items-start justify-between mb-4">
                <div>
                  <p className="font-mono font-bold text-lg text-foreground">{pedido.numero}</p>
                  <p className="text-sm text-muted-foreground">OS {pedido.os}</p>
                </div>
                <Badge className={getStatusColor(pedido.status)}>
                  {pedido.status}
                </Badge>
              </div>

              <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                <div>
                  <p className="text-xs text-muted-foreground">Cliente</p>
                  <p className="font-semibold text-foreground">{pedido.cliente}</p>
                </div>
                <div>
                  <p className="text-xs text-muted-foreground">Data</p>
                  <p className="font-semibold text-foreground">{pedido.data}</p>
                </div>
                <div>
                  <p className="text-xs text-muted-foreground">Materiais</p>
                  <p className="font-semibold text-foreground">{pedido.materiais.length} itens</p>
                </div>
                <div>
                  <p className="text-xs text-muted-foreground">Data Prevista</p>
                  <p className="font-semibold text-foreground">{pedido.dataPrevista || '-'}</p>
                </div>
              </div>

              {/* Materiais */}
              <div className="border-t border-border pt-4">
                <p className="text-sm font-semibold text-foreground mb-2">Materiais:</p>
                <div className="space-y-1">
                  {pedido.materiais.map((material, idx) => (
                    <p key={idx} className="text-sm text-muted-foreground">
                      • {material.codigo} - {material.descricao} ({material.quantidade} {material.unidade})
                    </p>
                  ))}
                </div>
              </div>

              {/* Botões de Ação */}
              <div className="flex gap-2 mt-4 pt-4 border-t border-border">
                <Button variant="outline" size="sm">
                  <Edit2 size={16} className="mr-2" />
                  Editar
                </Button>
                <Button variant="outline" size="sm" className="text-accent">
                  Enviar para Despacho
                </Button>
              </div>
            </Card>
          ))}
        </div>
      )}
    </div>
  );
}
