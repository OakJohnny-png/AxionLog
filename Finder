  { codigo: 'MAT-030', descricao: 'Espaçador de Cerâmica', categoria: 'Ferragens', localizacao: 'Bloco K - Prateleira 4', quantidade: 5000, unidade: 'unidades' },
];

export default function Finder() {
  const [busca, setBusca] = useState('');
  const [materialSelecionado, setMaterialSelecionado] = useState<Material | null>(null);

  // Filtrar materiais baseado na busca
  const materiaisFiltrados = useMemo(() => {
    if (!busca.trim()) return MATERIAIS_TESTE;

    const termoBusca = busca.toLowerCase();
    return MATERIAIS_TESTE.filter(
      material =>
        material.codigo.toLowerCase().includes(termoBusca) ||
        material.descricao.toLowerCase().includes(termoBusca) ||
        material.categoria.toLowerCase().includes(termoBusca) ||
        material.localizacao.toLowerCase().includes(termoBusca)
    );
  }, [busca]);

  // Agrupar por categoria
  const materiaisPorCategoria = useMemo(() => {
    const agrupados: { [key: string]: Material[] } = {};
    materiaisFiltrados.forEach(material => {
      if (!agrupados[material.categoria]) {
        agrupados[material.categoria] = [];
      }
      agrupados[material.categoria].push(material);
    });
    return agrupados;
  }, [materiaisFiltrados]);

  return (
    <div className="space-y-6">
      {/* Barra de Busca */}
      <div className="relative">
        <Search className="absolute left-3 top-3 text-muted-foreground" size={20} />
        <Input
          placeholder="Buscar por código, descrição, categoria ou localização..."
          value={busca}
          onChange={(e) => setBusca(e.target.value)}
          className="pl-10"
        />
      </div>

      {/* Resultados */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Lista de Materiais */}
        <div className="lg:col-span-2 space-y-4">
          {Object.entries(materiaisPorCategoria).length === 0 ? (
            <Card className="p-8 text-center">
              <p className="text-muted-foreground">Nenhum material encontrado</p>
            </Card>
          ) : (
            Object.entries(materiaisPorCategoria).map(([categoria, materiais]) => (
              <div key={categoria}>
                <h3 className="font-bold text-foreground mb-3 text-sm uppercase tracking-wide">
                  {categoria}
                </h3>
                <div className="space-y-2">
                  {materiais.map((material) => (
                    <Card
                      key={material.codigo}
                      className={`p-4 cursor-pointer transition-all border-l-4 ${
                        materialSelecionado?.codigo === material.codigo
                          ? 'border-l-accent bg-secondary'
                          : 'border-l-border hover:border-l-accent'
                      }`}
                      onClick={() => setMaterialSelecionado(material)}
                    >
                      <div className="flex items-start justify-between gap-2">
                        <div className="flex-1">
                          <p className="font-mono font-semibold text-sm text-foreground">
                            {material.codigo}
                          </p>
                          <p className="text-sm text-foreground mt-1">{material.descricao}</p>
                        </div>
                        <Badge variant="outline">{material.categoria}</Badge>
                      </div>
                    </Card>
                  ))}
                </div>
              </div>
            ))
          )}
        </div>

        {/* Detalhes do Material Selecionado */}
        <div>
          {materialSelecionado ? (
            <Card className="p-6 sticky top-20">
              <h3 className="font-bold text-foreground mb-4">Detalhes</h3>
              <div className="space-y-4">
                <div>
                  <p className="text-xs text-muted-foreground">Código</p>
                  <p className="font-mono font-semibold text-foreground">
                    {materialSelecionado.codigo}
                  </p>
                </div>

                <div>
                  <p className="text-xs text-muted-foreground">Descrição</p>
                  <p className="text-foreground">{materialSelecionado.descricao}</p>
                </div>

                <div>
                  <p className="text-xs text-muted-foreground">Categoria</p>
                  <Badge className="mt-1">{materialSelecionado.categoria}</Badge>
                </div>

                <div>
                  <p className="text-xs text-muted-foreground">Quantidade em Estoque</p>
                  <p className="text-lg font-bold text-accent">
                    {materialSelecionado.quantidade} {materialSelecionado.unidade}
                  </p>
                </div>

                <div className="pt-2 border-t border-border">
                  <div className="flex items-start gap-2">
                    <MapPin size={16} className="text-accent flex-shrink-0 mt-1" />
                    <div>
                      <p className="text-xs text-muted-foreground">Localização</p>
                      <p className="font-mono text-sm text-foreground">
                        {materialSelecionado.localizacao}
                      </p>
                    </div>
                  </div>
                </div>

                <Button className="w-full bg-accent text-accent-foreground">
                  <Package size={16} className="mr-2" />
                  Adicionar ao Pedido
                </Button>
              </div>
            </Card>
          ) : (
            <Card className="p-6 text-center">
              <p className="text-muted-foreground">Selecione um material para ver detalhes</p>
            </Card>
          )}
        </div>
      </div>

      {/* Resumo de Busca */}
      <Card className="p-4 bg-secondary">
        <p className="text-sm text-foreground">
          <strong>{materiaisFiltrados.length}</strong> material(is) encontrado(s)
          {busca && ` para "${busca}"`}
        </p>
      </Card>
    </div>
  );
}
